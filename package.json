{
  "name": "agentos",
  "version": "0.5.0",
  "description": "A process-model agent runtime: every agent is a process",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:live": "RUN_LIVE=1 vitest run tests/integration/deepseek.live.test.ts tests/integration/live.e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "server": "tsx server/index.ts"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
